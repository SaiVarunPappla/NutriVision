<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_background"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/llScanDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analysis Results"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textStyle="bold"
            android:textColor="@color/md_theme_light_onBackground"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvTrustLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NutriVision AI - educational, not medical advice"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/md_theme_light_secondary"
            android:layout_marginBottom="14dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvProductNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textStyle="bold"
                android:textColor="@color/md_theme_light_secondary"/>

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvConfidenceBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_confidence_badge"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="Confidence: -"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textStyle="bold"
                android:textColor="@color/md_theme_light_onSecondaryContainer"/>

            <TextView
                android:id="@+id/tvHealthScoreLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Health Score"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textStyle="bold"
                android:layout_marginTop="14dp" />

            <TextView
                android:id="@+id/tvHealthScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Health Score: 8.5 / 10"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="@color/md_theme_light_primary"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvIngredientsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingredients Found"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvRecommendationsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recommendations and Alerts"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold"
                android:textColor="@color/md_theme_light_error"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvAllergensLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allergens"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvAllergens"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:id="@+id/tvDietarySuitabilityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dietary Suitability"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDietarySuitability"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llNutrition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvNutritionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nutrition Facts"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvNutritionDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvNoDataAvailable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No analysis data available."
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/md_theme_light_error"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Done"
            app:cornerRadius="12dp"/>

        <TextView
            android:id="@+id/btnAskAi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ask NutriVision AI"
            android:textStyle="bold"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/md_theme_light_primary"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>